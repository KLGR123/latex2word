{
  "paths": {
    "rules_file": "configs/rules.json"
  },
  "preprocess": {
    "tex_verbose": true,
    "strip_formatting": true,
    "prefer_bbl_over_bib": true,
    "bib_sort": "year",
    "bib_dedup": true,
    "bib_lang": "en",
    "bib_start": 1,
    "chunk_encoding": "utf-8",
    "chunk_include_title": true,
    "chunk_keep_commands": true,
    "chunk_split_on_forced_linebreak": true,
    "chunk_strict": true
  },
  "translate": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "concurrency": 8,
    "max_batch_tokens": 1500,
    "api_key": null,
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com",
    "checkpoint": null,
    "terms": "configs/terms.json",
    "auto_terms": true,
    "strip_cjk_spaces": true,
    "debug": false,
    "cleanup_chunks": false
  },
  "postprocess": {
    "refmap_verbose": true,
    "replace_verbose": true,
    "replace_placeholder": "[未找到]",
    "render_skip_title": false,
    "overwrite_docx": true,
    "cleanup_translated": false,
    "cleanup_labeled": false
  }
}
